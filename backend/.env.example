# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=energy_dashboard
DB_USER=postgres
DB_PASSWORD=your_password_here

# AWS Configuration
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566  # LocalStack for local dev

# Shelly Integration
# Add your Shelly device configurations in devices.json

# Ecodirect Integration
ECODIRECT_API_URL=https://api.ecodirect.com
ECODIRECT_API_KEY=your_ecodirect_api_key_here

# UniFi Integration
UNIFI_PROTECT_URL=https://your-unifi-protect-host
UNIFI_ALARM_HUB_URL=https://your-alarm-hub-host
UNIFI_USERNAME=your_unifi_username
UNIFI_PASSWORD=your_unifi_password

# API Configuration
API_PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
